#!/usr/bin/env bash
# onionarmor â€” apply hardening recommendations to Ubuntu/Debian relay fleets.
#
# Sister to onionwarden (monitoring, read-only) and onionleak (audit). This
# tool MODIFIES host state with backup + rollback safety rails. Scope is
# kernel sysctls + (separately) GRUB-cmdline lockdown.

set -euo pipefail

# Locate the install prefix (parent of bin/). Use a portable readlink trick
# so symlinks to bin/onionarmor still work.
_oa_bin=${BASH_SOURCE[0]}
if [ -L "$_oa_bin" ]; then
  _oa_bin=$(readlink "$_oa_bin")
fi
case "$_oa_bin" in
  /*) ;;
  *)  _oa_bin="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "$_oa_bin")" ;;
esac
ONIONARMOR_PREFIX=$(cd "$(dirname "$_oa_bin")/.." && pwd)
export ONIONARMOR_PREFIX

# shellcheck source=lib/common.sh
. "$ONIONARMOR_PREFIX/lib/common.sh"
# shellcheck source=lib/role.sh
. "$ONIONARMOR_PREFIX/lib/role.sh"
# shellcheck source=lib/sysctl_ops.sh
. "$ONIONARMOR_PREFIX/lib/sysctl_ops.sh"
# shellcheck source=lib/module.sh
. "$ONIONARMOR_PREFIX/lib/module.sh"
# shellcheck source=lib/remediate.sh
. "$ONIONARMOR_PREFIX/lib/remediate.sh"

# ---------------------------------------------------------------------------
# Usage / help.
# ---------------------------------------------------------------------------
usage() {
  cat <<'EOF'
onionarmor â€” apply hardening recommendations idempotently, with rollback.

USAGE
  onionarmor <command> [options]

COMMANDS (sysctl roles)
  list      [--role <name>]              Show recommended sysctls + values.
  diff      [--role <name>]              Show current host values vs target.
  apply     [--role <name>] [--dry-run] [--first-run]
                                         Apply target sysctls. Backs up the
                                         prior managed file, writes the new
                                         one, then `sysctl --system`.
  rollback  [--role <name>]              Restore the most recent backup.
  audit                                  Print the audit log.
  apply-lockdown [--no-reboot]           Stage `lockdown=integrity` in GRUB
                                         cmdline (needs reboot). Documented
                                         but never auto-rebooted.

COMMANDS (modules)
  list-modules                           List installed hardening modules.
  apply   --module <name> [module opts]  Apply a module's posture.
  audit   --module <name> [module opts]  Green/yellow/red status; non-zero
                                         exit if any check is red.
  revert  --module <name> [module opts]  Undo a module's posture.
  Run `onionarmor apply --module <name> --help` for that module's own flags.

COMMANDS (auditor-driven)
  remediate --from-audit <scorecard.json> [--dry-run|--apply]
                                         Read an onionauditor JSON scorecard,
                                         map failing/warning findings to the
                                         modules that fix them, and print an
                                         ordered apply plan (kernel first,
                                         firewall before service-inventory, SSH
                                         last). --dry-run (default) plans only;
                                         --apply runs each module's apply.

  help                                   Show this help.

SAFETY RAILS
  * `apply` refuses unless --role is set AND /etc/onionarmor/role.conf says
    the same role (cross-check to prevent applying tor-relay profile to a
    workstation).
  * Every apply makes a timestamped backup of the prior managed file.
  * `apply --first-run` requires explicit confirmation.
  * Idempotent â€” re-running apply with no role-config change produces no diff.
  * Lockdown changes need reboot â€” never auto-applied by `apply`.

ENV OVERRIDES (testing)
  ONIONARMOR_ROLES_DIR, ONIONARMOR_ETC_DIR, ONIONARMOR_SYSCTL_DIR,
  ONIONARMOR_AUDIT_LOG, ONIONARMOR_SYSCTL_CMD, ONIONARMOR_GRUB_FILE,
  ONIONARMOR_UPDATE_GRUB_CMD, ONIONARMOR_AUTO_CONFIRM, ONIONARMOR_SKIP_RELOAD.
EOF
}

# ---------------------------------------------------------------------------
# Argument parsing: extract --role and recognise --dry-run / --first-run /
# --no-reboot. Unknown args -> error.
# ---------------------------------------------------------------------------
_oa_role=""
_oa_dry_run=0
_oa_first_run=0
_oa_no_reboot=0

oa_parse_args() {
  while [ $# -gt 0 ]; do
    case "$1" in
      --role)      _oa_role=${2:-};  shift 2 ;;
      --role=*)    _oa_role=${1#--role=}; shift ;;
      --dry-run)   _oa_dry_run=1;   shift ;;
      --first-run) _oa_first_run=1; shift ;;
      --no-reboot) _oa_no_reboot=1; shift ;;
      -h|--help)   usage; exit 0 ;;
      *)           die "unknown argument: $1" ;;
    esac
  done
}

# ---------------------------------------------------------------------------
# cmd_list â€” show role's target values + DOC/REF/COMPAT.
# Pure read; never touches the host.
# ---------------------------------------------------------------------------
cmd_list() {
  oa_parse_args "$@"
  require_role list
  info "role=$_oa_role file=$(role_file_for "$_oa_role")"
  printf '\n%-40s %s\n' "SYSCTL" "TARGET"
  printf '%-40s %s\n' "----------------------------------------" "------"
  # Parse once: render the table and report the count via awk's END so the role
  # file is read a single time.
  role_parse "$_oa_role" \
    | awk '{printf "%-40s %s\n", $1, $2} END {printf "\n%d sysctl entries.\n", NR}'
  printf '\n(Use `onionarmor diff --role %s` to compare to live host.)\n' "$_oa_role"
}

# ---------------------------------------------------------------------------
# cmd_diff â€” current host value vs target. Read-only.
# Exit 0 even if there is a diff; exit code reflects errors only.
# ---------------------------------------------------------------------------
cmd_diff() {
  oa_parse_args "$@"
  require_role diff
  local key target current diffs=0 total=0
  # shellcheck disable=SC2059  # format is a centralised constant, not user input
  printf "$_OA_FMT_SYSCTL_ROW" "SYSCTL" "CURRENT" "TARGET" "STATUS"
  # shellcheck disable=SC2059
  printf "$_OA_FMT_SYSCTL_ROW" "$_OA_DASH_SYSCTL_ROW" "$_OA_DASH_SYSCTL_COL" "$_OA_DASH_SYSCTL_COL" "------"
  while read -r key target; do
    total=$((total + 1))
    current=$(sysctl_current "$key")
    if [ -z "$current" ]; then
      # shellcheck disable=SC2059
      printf "$_OA_FMT_SYSCTL_ROW" "$key" "?" "$target" "missing"
      diffs=$((diffs + 1))
    elif [ "$(sysctl_normalise_value "$current")" = "$(sysctl_normalise_value "$target")" ]; then
      # shellcheck disable=SC2059
      printf "$_OA_FMT_SYSCTL_ROW" "$key" "$current" "$target" "ok"
    else
      # shellcheck disable=SC2059
      printf "$_OA_FMT_SYSCTL_ROW" "$key" "$current" "$target" "DRIFT"
      diffs=$((diffs + 1))
    fi
  done < <(role_parse "$_oa_role")
  printf '\n%d/%d sysctls drift from target.\n' "$diffs" "$total"
}

# ---------------------------------------------------------------------------
# cmd_apply â€” write target sysctls to /etc/sysctl.d/99-onionarmor-<role>.conf
# with safety rails.
# ---------------------------------------------------------------------------
cmd_apply() {
  oa_parse_args "$@"
  require_role apply
  host_role_assert "$_oa_role"

  if [ "$_oa_first_run" -eq 1 ] && [ "$_oa_dry_run" -eq 0 ]; then
    printf 'First-run apply for role=%s on host classified as %s.\n' \
      "$_oa_role" "$_oa_role" >&2
    oa_confirm "Proceed with applying $_oa_role posture to this host?" \
      || die "first-run apply cancelled by operator"
  fi

  local key target current changes=0 noops=0 errs=0
  # Use script-global temp vars so the EXIT trap can see them after this
  # function returns; locals would be unset by then under `set -u`.
  pairs_tmp=$(mktemp)
  diff_tmp=$(mktemp)
  trap 'rm -f "${pairs_tmp:-}" "${diff_tmp:-}"' EXIT
  role_parse "$_oa_role" > "$pairs_tmp"

  while read -r key target; do
    current=$(sysctl_current "$key")
    if [ "$(sysctl_normalise_value "$current")" = "$(sysctl_normalise_value "$target")" ]; then
      printf '%s\t%s\t%s\tnoop\n' "$key" "$current" "$target" >> "$diff_tmp"
      noops=$((noops + 1))
    else
      printf '%s\t%s\t%s\tchange\n' "$key" "${current:-?}" "$target" >> "$diff_tmp"
      changes=$((changes + 1))
    fi
  done < "$pairs_tmp"

  if [ "$_oa_dry_run" -eq 1 ]; then
    info "dry-run: role=$_oa_role changes=$changes noops=$noops"
    printf '\n'
    # shellcheck disable=SC2059  # format is a centralised constant, not user input
    printf "$_OA_FMT_SYSCTL_ROW" "SYSCTL" "CURRENT" "TARGET" "ACTION"
    # shellcheck disable=SC2059
    printf "$_OA_FMT_SYSCTL_ROW" "$_OA_DASH_SYSCTL_ROW" "$_OA_DASH_SYSCTL_COL" "$_OA_DASH_SYSCTL_COL" "------"
    awk -F'\t' -v fmt="$_OA_FMT_SYSCTL_ROW" '{printf fmt, $1, $2, $3, $4}' "$diff_tmp"
    printf '\nNo changes written. Re-run without --dry-run to apply.\n'
    return 0
  fi

  audit_log apply.start "role=$_oa_role changes=$changes noops=$noops first_run=$_oa_first_run"

  local backup=""
  backup=$(backup_managed_sysctl "$_oa_role") || true
  if [ -n "$backup" ]; then
    audit_log apply.backup "role=$_oa_role backup=$backup"
  fi

  write_managed_sysctl "$_oa_role" "$pairs_tmp" \
    || audit_fail_die apply.fail "role=$_oa_role stage=write" "failed to write managed sysctl file"

  if ! reload_sysctl; then
    audit_log apply.fail "role=$_oa_role stage=reload"
    warn "sysctl --system reload returned nonzero; managed file was written but some keys may not be active"
    errs=$((errs + 1))
  fi

  while IFS=$'\t' read -r key cur tgt act; do
    [ "$act" = "change" ] || continue
    audit_log apply.change "role=$_oa_role key=$key old=$cur new=$tgt"
  done < "$diff_tmp"

  audit_log apply.done "role=$_oa_role changes=$changes noops=$noops errors=$errs"
  info "apply: role=$_oa_role changes=$changes noops=$noops errors=$errs"
  [ "$errs" -eq 0 ] || exit 2
}

# ---------------------------------------------------------------------------
# cmd_rollback â€” restore the most recent backup.
# ---------------------------------------------------------------------------
cmd_rollback() {
  oa_parse_args "$@"
  require_role rollback
  host_role_assert "$_oa_role"

  local latest target
  latest=$(newest_backup "$_oa_role")
  target=$(managed_sysctl_path "$_oa_role")
  [ -n "$latest" ] || die "no backups to restore for role=$_oa_role"

  audit_log rollback.start "role=$_oa_role from=$latest to=$target"
  cp -p "$latest" "$target" \
    || audit_fail_die rollback.fail "role=$_oa_role stage=copy" "rollback copy failed"
  reload_sysctl \
    || audit_fail_warn rollback.fail "role=$_oa_role stage=reload" "sysctl reload returned nonzero"
  audit_log rollback.done "role=$_oa_role restored=$latest"
  info "rollback: restored $latest -> $target"
}

# ---------------------------------------------------------------------------
# cmd_audit â€” print the audit log.
# ---------------------------------------------------------------------------
cmd_audit() {
  if [ ! -r "$ONIONARMOR_AUDIT_LOG" ]; then
    info "audit log is empty (no operations recorded yet): $ONIONARMOR_AUDIT_LOG"
    return 0
  fi
  printf 'TIMESTAMP\tOPERATOR\tACTION\tDETAILS\n'
  cat "$ONIONARMOR_AUDIT_LOG"
}

# ---------------------------------------------------------------------------
# cmd_apply_lockdown â€” stage `lockdown=integrity` in GRUB cmdline.
# Never auto-reboots. Without --no-reboot it prints a REBOOT REQUIRED warning.
# ---------------------------------------------------------------------------
cmd_apply_lockdown() {
  oa_parse_args "$@"
  local f=$ONIONARMOR_GRUB_FILE tmp
  [ -r "$f" ] || die "GRUB file not found or unreadable: $f"
  [ -w "$f" ] || die "GRUB file not writable (run as root?): $f"

  audit_log lockdown.start "file=$f"
  tmp="$f.onionarmor.$$"

  awk '
    BEGIN { changed = 0 }
    /^GRUB_CMDLINE_LINUX_DEFAULT[[:space:]]*=/ {
      if ($0 ~ /lockdown=/) {
        gsub(/lockdown=[a-z]+/, "lockdown=integrity")
      } else {
        # Insert before the closing quote.
        sub(/"[[:space:]]*$/, " lockdown=integrity\"")
      }
      changed = 1
    }
    { print }
    END {
      if (changed == 0) exit 3
    }
  ' "$f" > "$tmp" || { rm -f "$tmp"; audit_fail_die lockdown.fail "stage=awk" "no GRUB_CMDLINE_LINUX_DEFAULT line found in $f"; }

  mv "$tmp" "$f" \
    || audit_fail_die lockdown.fail "stage=move" "cannot replace $f"

  if [ "${ONIONARMOR_SKIP_UPDATE_GRUB:-}" != "yes" ]; then
    "$ONIONARMOR_UPDATE_GRUB_CMD" >/dev/null 2>&1 \
      || audit_fail_warn lockdown.fail "stage=update-grub" "$ONIONARMOR_UPDATE_GRUB_CMD returned nonzero; lockdown change is in $f but may not be active until you fix this"
  fi

  audit_log lockdown.done "file=$f reboot_required=true no_reboot=$_oa_no_reboot"

  if [ "$_oa_no_reboot" -eq 1 ]; then
    info "lockdown staged in $f. Apply on next manual reboot."
  else
    cat >&2 <<EOF

============================================================
REBOOT REQUIRED
============================================================
Kernel lockdown=integrity has been staged in $f.
It will take effect on next reboot. Reboot when convenient.
onionarmor does NOT reboot automatically.
============================================================
EOF
  fi
}

# ---------------------------------------------------------------------------
# cmd_list_modules â€” list installed hardening modules + one-line descriptions.
# ---------------------------------------------------------------------------
cmd_list_modules() {
  local any=0 name desc
  while read -r name; do
    [ -n "$name" ] || continue
    any=1
    desc=$(module_describe "$name")
    printf '%-16s %s\n' "$name" "$desc"
  done < <(module_list)
  if [ "$any" -eq 0 ]; then
    info "no modules installed under $ONIONARMOR_MODULES_DIR"
  fi
}

# ---------------------------------------------------------------------------
# cmd_remediate â€” read an onionauditor scorecard and drive module remediation.
# Default is --dry-run (plan only); --apply runs each mapped module's apply in
# the safe order. Read-only unless --apply is given.
# ---------------------------------------------------------------------------
cmd_remediate() {
  local scorecard="" mode="dry-run"
  while [ $# -gt 0 ]; do
    case "$1" in
      --from-audit)   scorecard=${2:-}; shift 2 ;;
      --from-audit=*) scorecard=${1#--from-audit=}; shift ;;
      --dry-run)      mode="dry-run"; shift ;;
      --apply)        mode="apply"; shift ;;
      -h|--help)      usage; exit 0 ;;
      *)              die "remediate: unknown argument: $1" ;;
    esac
  done

  [ -n "$scorecard" ] || die "remediate: --from-audit <scorecard.json> is required"
  [ -r "$scorecard" ] || die "remediate: scorecard not found or unreadable: $scorecard"
  command -v "$ONIONARMOR_JQ_CMD" >/dev/null 2>&1 \
    || die "remediate: '$ONIONARMOR_JQ_CMD' not found â€” install jq (apt install jq) to parse the scorecard"

  local host profile grade generated
  host=$(remediate_meta "$scorecard" host)
  profile=$(remediate_meta "$scorecard" profile)
  grade=$(remediate_meta "$scorecard" grade)
  generated=$(remediate_meta "$scorecard" generated)

  # Map every actionable finding to a module. mapped: module \t category \t
  # status \t severity \t name \t detail (bash-3.2: temp file, not assoc array).
  local mapped; mapped=$(mktemp)
  trap 'rm -f "${mapped:-}" "${ordered:-}"' EXIT
  local category status severity name explicit detail module any=0
  while IFS=$'\t' read -r category status severity name explicit detail; do
    [ -n "$category" ] || continue
    any=1
    # "-" is the placeholder remediate_extract emits for an empty interior field.
    [ "$explicit" = "-" ] && explicit=""
    [ "$severity" = "-" ] && severity=""
    [ "$detail" = "-" ] && detail=""
    module=$explicit
    [ -n "$module" ] || module=$(remediate_module_for_category "$category")
    [ -n "$module" ] || module="(unmapped:$category)"
    printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$module" "$category" "$status" "$severity" "$name" "$detail" >> "$mapped"
  done < <(remediate_extract "$scorecard")

  printf 'onionarmor remediate â€” plan from %s\n' "$scorecard"
  printf 'host=%s profile=%s grade=%s generated=%s\n\n' "$host" "$profile" "$grade" "$generated"

  if [ "$any" -eq 0 ] || [ ! -s "$mapped" ]; then
    info "no findings with status fail/warn â€” nothing to remediate"
    return 0
  fi

  # Unique modules, ordered by apply rank (ssh-hardening forced last).
  local ordered; ordered=$(mktemp)
  cut -f1 "$mapped" | sort -u | while read -r module; do
    [ -n "$module" ] || continue
    printf '%s\t%s\n' "$(remediate_rank "$module")" "$module"
  done | sort -n -k1,1 -k2 | cut -f2 > "$ordered"

  printf 'Findings needing remediation (status fail|warn), grouped by module:\n\n'
  local idx=0 count installed mark
  while read -r module; do
    [ -n "$module" ] || continue
    idx=$((idx + 1))
    count=$(awk -F'\t' -v m="$module" '$1==m' "$mapped" | grep -c .)
    case "$module" in
      \(unmapped:*\)) installed="no module maps to this category" ;;
      *) if module_is_valid "$module" 2>/dev/null; then installed="installed"; else installed="NOT installed (skipped on --apply)"; fi ;;
    esac
    mark=""
    [ "$module" = "ssh-hardening" ] && mark="   [APPLIED LAST]"
    printf '  [%d] %-22s %2d finding(s)   %s%s\n' "$idx" "$module" "$count" "$installed" "$mark"
    # Up to 3 sample findings for context.
    awk -F'\t' -v m="$module" '$1==m {printf "        - %s (%s): %s\n", $5, $3, substr($6,1,72)}' "$mapped" | head -3
  done < "$ordered"

  printf '\nApply order: kernel-hardening first (safe anytime); firewall-default-deny\n'
  printf 'before service-inventory; ssh-hardening LAST (verify the rest before risking SSH).\n'

  if [ "$mode" = "dry-run" ]; then
    printf '\nDRY-RUN: no modules applied. Re-run with --apply to execute.\n'
    return 0
  fi

  # --- --apply: run each module in order; track results. -------------------
  printf '\n--apply: running module remediation in order...\n\n'
  audit_log remediate.start "scorecard=$scorecard host=$host modules=$(tr '\n' ',' < "$ordered")"
  local prior_failure=0 ran=0 ok=0 failed=0 skipped=0 rc
  while read -r module; do
    [ -n "$module" ] || continue
    case "$module" in
      \(unmapped:*\))
        printf '  SKIP  %-22s (no module maps to this category)\n' "$module"
        skipped=$((skipped + 1)); continue ;;
    esac
    if ! module_is_valid "$module" 2>/dev/null; then
      printf '  SKIP  %-22s (module not installed on this host)\n' "$module"
      audit_log remediate.skip "module=$module reason=not-installed"
      skipped=$((skipped + 1)); continue
    fi
    # Safety: never take on the SSH-lockout risk if an earlier posture failed.
    if [ "$module" = "ssh-hardening" ] && [ "$prior_failure" -ne 0 ]; then
      printf '  SKIP  %-22s (a prior module failed â€” refusing SSH risk until clean)\n' "$module"
      audit_log remediate.skip "module=$module reason=prior-failure"
      skipped=$((skipped + 1)); continue
    fi
    printf '  RUN   %-22s ...\n' "$module"
    ran=$((ran + 1))
    if remediate_run_module "$module"; then
      rc=0; ok=$((ok + 1)); printf '  OK    %-22s\n' "$module"
      audit_log remediate.module "module=$module result=ok"
    else
      rc=$?; failed=$((failed + 1)); prior_failure=1
      printf '  FAIL  %-22s (exit %d)\n' "$module" "$rc"
      audit_log remediate.module "module=$module result=fail rc=$rc"
    fi
  done < "$ordered"

  audit_log remediate.done "ran=$ran ok=$ok failed=$failed skipped=$skipped"
  printf '\nremediate: ran=%d ok=%d failed=%d skipped=%d\n' "$ran" "$ok" "$failed" "$skipped"
  [ "$failed" -eq 0 ] || exit 2
}

# ---------------------------------------------------------------------------
# Dispatch. apply/audit/revert route to a MODULE when --module is present,
# otherwise keep the existing role-based sysctl behaviour.
# ---------------------------------------------------------------------------
main() {
  [ $# -ge 1 ] || { usage; exit 2; }
  local cmd=$1; shift
  case "$cmd" in
    list)            cmd_list "$@" ;;
    diff)            cmd_diff "$@" ;;
    apply)
      if args_have_module "$@"; then module_dispatch apply "$@"
      else cmd_apply "$@"; fi ;;
    audit)
      if args_have_module "$@"; then module_dispatch audit "$@"
      else cmd_audit "$@"; fi ;;
    revert)
      args_have_module "$@" \
        || die "revert requires --module <name> (for sysctl roles use: rollback --role <r>)"
      module_dispatch revert "$@" ;;
    rollback)        cmd_rollback "$@" ;;
    remediate)       cmd_remediate "$@" ;;
    list-modules)    cmd_list_modules "$@" ;;
    apply-lockdown)  cmd_apply_lockdown "$@" ;;
    help|--help|-h)  usage ;;
    *)               die "unknown command: $cmd (try: onionarmor help)" ;;
  esac
}

main "$@"
